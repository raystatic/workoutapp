-- Placeholder table proving the DI/SQLDelight/repository/Flow plumbing works
-- end to end. The real logging schema (Exercise, Routine, Workout, ...) lands
-- in a subsequent issue; this table is scaffolding only.
CREATE TABLE sampleNote (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    text TEXT NOT NULL
);

selectAll:
SELECT * FROM sampleNote ORDER BY id DESC;

insertNote:
INSERT INTO sampleNote(text) VALUES (?);

deleteById:
DELETE FROM sampleNote WHERE id = ?;
